        ],
        "title": "BatchJobResponse"
      },
      "Body_detect_api_detect_post": {
        "properties": {
          "file": {
            "type": "string",
            "format": "binary",
            "title": "File"
          },
          "use_sam": {
            "type": "boolean",
            "title": "Use Sam",
            "default": true
          },
          "confidence": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Confidence"
          }
        },
        "type": "object",
        "required": [
          "file"
        ],
        "title": "Body_detect_api_detect_post"
      },
      "Body_detect_batch_api_detect_batch_post": {
        "properties": {
          "files": {
            "items": {
              "type": "string",
              "format": "binary"
            },
            "type": "array",
            "title": "Files"
          },
          "use_sam": {
            "type": "boolean",
            "title": "Use Sam",
            "default": true
          },
          "confidence": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Confidence"
          }
        },
        "type": "object",
        "required": [
          "files"
        ],
        "title": "Body_detect_batch_api_detect_batch_post"
      },
      "DetectMeta": {
        "properties": {
          "inference_ms": {
            "type": "integer",
            "title": "Inference Ms"
          },
          "num_detections": {
            "type": "integer",
            "title": "Num Detections"
          },
          "sam_used": {
            "type": "boolean",
            "title": "Sam Used"
          },
          "yolo_model": {
            "type": "string",
            "title": "Yolo Model"
          },
          "device": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Device"
          }
        },
        "type": "object",
        "required": [
          "inference_ms",
          "num_detections",
          "sam_used",
          "yolo_model"
        ],
        "title": "DetectMeta"
      },
      "DetectResponse": {
        "properties": {
          "run_id": {
            "type": "string",
            "title": "Run Id"
          },
          "detections": {
            "items": {
              "$ref": "#/components/schemas/DetectionItem"
            },
            "type": "array",
            "title": "Detections"
          },
          "annotated_image_url": {
            "type": "string",
            "title": "Annotated Image Url"
          },
          "meta": {
            "$ref": "#/components/schemas/DetectMeta"
          }
        },
        "type": "object",
        "required": [
          "run_id",
          "detections",
          "annotated_image_url",
          "meta"
        ],
        "title": "DetectResponse"
      },
      "DetectionItem": {
        "properties": {
          "class": {
            "type": "string",
            "title": "Class",
            "description": "\uc601\ubb38 \ud074\ub798\uc2a4\uba85"
          },
          "class_kr": {
            "type": "string",
            "title": "Class Kr",
            "description": "\ud55c\uae00 \ud074\ub798\uc2a4\uba85"
          },
          "score": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Score"
          },
          "bbox": {
            "items": {
              "type": "integer"
            },
            "type": "array",
            "maxItems": 4,
            "minItems": 4,
            "title": "Bbox",
            "description": "[x1,y1,x2,y2]"
          },
          "mask_url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Mask Url",
            "description": "SAM \ub9c8\uc2a4\ud06c PNG URL, \uc5c6\uc73c\uba74 null"
          }
        },
        "type": "object",
        "required": [
          "class",
          "class_kr",
          "score",
          "bbox"
        ],
        "title": "DetectionItem"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
